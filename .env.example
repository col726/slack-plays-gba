# Slack credentials
# Bot token from your Slack app's "OAuth & Permissions" page
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-level token from your Slack app's "Basic Information" > "App-Level Tokens"
# Requires the connections:write scope
SLACK_APP_TOKEN=xapp-your-app-token

# Channel ID (right-click channel > "Copy channel ID")
SLACK_CHANNEL_ID=C0123456789

# Path to your ROM (.gb or .gbc file)
ROM_PATH=/path/to/your-game.gb

# Game mode: "anarchy" (every command runs immediately) or "democracy" (vote-based)
MODE=anarchy

# Democracy mode: how many seconds to collect votes before executing the winner
DEMOCRACY_WINDOW=10

# How often (seconds) to post a screenshot to Slack
SCREENSHOT_INTERVAL=30

# How many frames to hold a button press (higher = longer press)
FRAMES_PER_INPUT=6

# Twitch chat bot (optional)
# 1. Register an app at https://dev.twitch.tv/console and set redirect URL to http://localhost
# 2. Open this URL in your browser (replace YOUR_CLIENT_ID):
#    https://id.twitch.tv/oauth2/authorize?client_id=YOUR_CLIENT_ID&redirect_uri=http://localhost&response_type=token&scope=chat:read+chat:edit
# 3. After authorizing, copy the token from the redirect URL: http://localhost#access_token=xxxxx
TWITCH_BOT_TOKEN=
TWITCH_CHANNEL=yourchannel

# Twitch streaming (optional)
# Leave TWITCH_STREAM_KEY blank to disable streaming entirely
# Get your stream key from: twitch.tv/dashboard/settings → Stream
TWITCH_STREAM_KEY=
STREAM_FPS=30
